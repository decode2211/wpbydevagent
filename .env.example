# Meta / WhatsApp Cloud API Config
META_ACCESS_TOKEN=your_meta_access_token_here
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
META_APP_SECRET=your_meta_app_secret_here
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Tenant phone number mappings in JSON format (maps Meta Phone ID to tenant_id)
# Example: {"1234567890": "tenant_luxfurn", "0987654321": "tenant_autocare"}
PHONE_NUMBER_TENANT_MAP={"your_phone_id_a":"tenant_luxfurn","your_phone_id_b":"tenant_autocare"}

# LLM Selection
LLM_PROVIDER=groq   # Options: 'groq', 'anthropic', 'openai', 'mock'
GROQ_API_KEY=gsk_your_key_here
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Database Connection
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.i0p6ep5.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=devyash1122

# App Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000
